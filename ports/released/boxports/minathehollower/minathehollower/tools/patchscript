#!/bin/bash

GAMEDIR="${GAMEDIR:-$PWD}"
DATA="$GAMEDIR/data"
TOOLS="$GAMEDIR/tools"
LOGFILE="patchlog.txt"
LOGERR="patcherr.txt"

rm -f "$GAMEDIR/$LOGERR"
exec 3>&1
> "$GAMEDIR/$LOGFILE" && exec > >(tee "$GAMEDIR/$LOGFILE") 2>&1

emit_fail_msg() {
    echo "PATCH_FAIL_MSG:$1" >&3
    echo "$1"
    FAIL_MSG_SET=1
}

echo "GAMEDIR is set to: $GAMEDIR"

SEVENZIP="$controlfolder/7zzs.${DEVICE_ARCH}"
WORKDIR="$DATA/.gogextract"

looks_like_installer() {
    head -c 16384 "$1" 2>/dev/null | grep -qE 'filesizes="[0-9]+"'
}

find_installer() {
    # Return the first .sh in data/ that is actually a GOG/Humble installer.
    local f
    for f in "$DATA"/*.sh; do
        [ -f "$f" ] || continue
        looks_like_installer "$f" && { echo "$f"; return 0; }
    done
    return 1
}

extract_game() {
    local installer="$1"
    echo "Installer: $installer"

    if [ ! -x "$SEVENZIP" ] && [ ! -f "$SEVENZIP" ]; then
        emit_fail_msg "7zzs not found at $SEVENZIP. Please update PortMaster."
        return 1
    fi
    if ! command -v python3 >/dev/null 2>&1; then
        emit_fail_msg "python3 not found on this device; cannot unpack the GOG installer."
        return 1
    fi

    rm -rf "$WORKDIR"
    mkdir -p "$WORKDIR/unz"

    # Split the MojoSetup installer into its game data archive
    echo "Splitting GOG installer..."
    if ! python3 "$TOOLS/gogextract.py" "$installer" "$WORKDIR"; then
        emit_fail_msg "Failed to split the GOG installer. Is it a valid Linux .sh?"
        return 1
    fi
    if [ ! -f "$WORKDIR/data.zip" ]; then
        emit_fail_msg "GOG installer produced no data archive."
        return 1
    fi

    # Unpack the game payload
    echo "Unpacking game files..."
    if ! "$SEVENZIP" x -y -o"$WORKDIR/unz" "$WORKDIR/data.zip" "data/noarch/game/*" -r >/dev/null; then
        emit_fail_msg "Failed to unpack the game data archive."
        return 1
    fi

    local game_src="$WORKDIR/unz/data/noarch/game"
    if [ ! -f "$game_src/MinaTheHollower" ]; then
        emit_fail_msg "Unpacked archive is missing MinaTheHollower."
        return 1
    fi

    # Flatten data/noarch/game/* up into data/
    echo "Installing game files..."
    mv "$game_src"/* "$DATA/" || { emit_fail_msg "Failed to move game files into place."; return 1; }

    chmod +x "$DATA/MinaTheHollower"
}

cleanup() {
    rm -rf "$WORKDIR"
    rm -f "$DATA"/mina_the_hollower_*.sh "$DATA"/*.sh 2>/dev/null
    rm -f "$DATA"/goggame-*.info "$DATA"/goggame-*.hashdb 2>/dev/null
    rm -f "$DATA/.gitkeep" 2>/dev/null
}

process() {
    local installer
    installer="$(find_installer)"
    if [ -z "$installer" ]; then
        emit_fail_msg "No GOG/Humble Linux installer (.sh) found in the data folder. Copy the Linux offline installer there, or the already-extracted game files."
        return 1
    fi
    extract_game "$installer" || return 1
    cleanup
    [ -f "$DATA/MinaTheHollower" ] || { emit_fail_msg "Extraction finished but MinaTheHollower is missing."; return 1; }
}

if ! process; then
    [ -z "$FAIL_MSG_SET" ] && emit_fail_msg "Extraction failed. Report on the RHH-Ports GitHub with patcherr.txt."
    echo "Extraction failed!"
    mv "$GAMEDIR/$LOGFILE" "$GAMEDIR/$LOGERR"
    exit 1
fi
echo "Extraction complete!"
