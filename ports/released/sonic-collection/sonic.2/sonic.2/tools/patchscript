#!/bin/sh

GAMEDIR="$PWD"
LOGFILE="patchlog.txt"
LOGERR="patcherr.txt"

# Logging
> "$GAMEDIR/$LOGFILE" && exec > >(tee "$GAMEDIR/$LOGFILE") 2>&1
echo "GAMEDIR is set to: $GAMEDIR"

TARGET="$GAMEDIR/Data.rsdk"
ORIGINS="$GAMEDIR/Sonic2u.rsdk"
DATADIR="$GAMEDIR/Data"
TMPDIR="$GAMEDIR/tmp"
MUSICDIR="$DATADIR/Music"
SFXDIR="$DATADIR/SoundFX"
TOOLSDIR="$GAMEDIR/tools"

# Audio pack source files — user drops these in $GAMEDIR.
MUSIC_ACB="$GAMEDIR/STH2_music.acb"
MUSIC_AWB="$GAMEDIR/STH2_music.awb"
SFX_ACB="$GAMEDIR/STH2_sfx.acb"
HITE_ACB="$GAMEDIR/HITE_sfx.acb"
# Sonic 2 shares several audio cues with Sonic 1 that Origins only ships
# under STH1. Require the STH1 packs too:
#   STH1_music.awb — Drowning track, 1up jingle
#   STH1_sfx.acb   — ScoreAdd, Event
STH1_MUSIC_AWB="$GAMEDIR/STH1_music.awb"
STH1_SFX_ACB="$GAMEDIR/STH1_sfx.acb"

# HCA keycodes per https://rsdkmodding.com/Games/SonicOrigins/Documentation/Audio/
STH2_MUSIC_KEY="7014663803770805356"
STH2_SFX_KEY="1290919142773486504"
STH1_MUSIC_KEY="6005974353133017519"
STH1_SFX_KEY="11064953427723590053"
HITE_SFX_KEY="1441441318033510872"

EXTRACTOR="$TOOLSDIR/rsdkv5u-extract"
FILELIST="$TOOLSDIR/RSDKv5UFileList.txt"
VGMSTREAM="$TOOLSDIR/vgmstream-cli"
OGGENC="$TOOLSDIR/oggenc"
NORMALIZE="$TOOLSDIR/wav-normalize"
SPEED="$TOOLSDIR/wav-speed"
GCPATCH="$TOOLSDIR/patch-gameconfig"

# Origins SFX are mastered ~8dB quieter than mobile. Normalize to -3dBFS.
SFX_TARGET_DBFS="-3"

# === Pre-flight: fail loudly if inputs are incomplete ===
# Accepted starting states:
#   A) Origins bundle: Sonic2u.rsdk + STH2_music.acb/awb + STH2_sfx.acb + HITE_sfx.acb
#   B) Mobile-only pass-through: Data.rsdk already mobile-signed (RSDKvB)
#   C) Already-extracted pass-through: Data/Game/GameConfig.bin exists
check_inputs() {
    # Pass-through shortcuts — no source files needed.
    if [ -f "$DATADIR/Game/GameConfig.bin" ]; then
        echo "Existing extracted Data/ detected — no new drops to process."
        return 0
    fi
    if [ -f "$TARGET" ]; then
        sig=$(dd if="$TARGET" bs=1 count=6 2>/dev/null)
        case "$sig" in
            RSDKvB)
                echo "Mobile Data.rsdk detected — engine will load it directly."
                return 0
                ;;
            RSDKv4)
                echo "ERROR: Data.rsdk has Origins signature."
                echo "       Rename it to Sonic2u.rsdk so the extractor picks it up,"
                echo "       then provide the Origins audio files too:"
                echo "         STH2_music.acb, STH2_music.awb, STH2_sfx.acb"
                return 1
                ;;
            *)
                echo "ERROR: Data.rsdk has unrecognized signature: '$sig'"
                return 1
                ;;
        esac
    fi

    # Origins path — require all seven files.
    missing=""
    [ -f "$ORIGINS" ]         || missing="${missing}  Sonic2u.rsdk\n"
    [ -f "$MUSIC_ACB" ]       || missing="${missing}  STH2_music.acb\n"
    [ -f "$MUSIC_AWB" ]       || missing="${missing}  STH2_music.awb\n"
    [ -f "$SFX_ACB" ]         || missing="${missing}  STH2_sfx.acb\n"
    [ -f "$HITE_ACB" ]        || missing="${missing}  HITE_sfx.acb\n"
    [ -f "$STH1_MUSIC_AWB" ]  || missing="${missing}  STH1_music.awb\n"
    [ -f "$STH1_SFX_ACB" ]    || missing="${missing}  STH1_sfx.acb\n"
    if [ -n "$missing" ]; then
        echo "ERROR: missing required files in $GAMEDIR:"
        printf "$missing"
        echo ""
        echo "This port needs the following from Sonic Origins:"
        echo "  Sonic2u.rsdk      — image/x64/raw/retro/Sonic2u.rsdk"
        echo "  STH2_music.acb    — image/x64/raw/sound/STH2_music.acb"
        echo "  STH2_music.awb    — image/x64/raw/sound/STH2_music.awb"
        echo "  STH2_sfx.acb      — image/x64/raw/sound/STH2_sfx.acb"
        echo "  HITE_sfx.acb      — image/x64/raw/sound/HITE_sfx.acb"
        echo "  STH1_music.awb    — image/x64/raw/sound/STH1_music.awb"
        echo "                      (Drowning + 1Up, shared with Sonic 1)"
        echo "  STH1_sfx.acb      — image/x64/raw/sound/STH1_sfx.acb"
        echo "                      (ScoreAdd + Event, shared with Sonic 1)"
        echo ""
        echo "Drop all seven into this folder and relaunch."
        return 1
    fi
    return 0
}

check_tools() {
    [ -f "$EXTRACTOR" ] && $ESUDO chmod +x "$EXTRACTOR" 2>/dev/null
    [ -f "$VGMSTREAM" ] && $ESUDO chmod +x "$VGMSTREAM" 2>/dev/null
    [ -f "$OGGENC" ]    && $ESUDO chmod +x "$OGGENC"    2>/dev/null
    [ -f "$NORMALIZE" ] && $ESUDO chmod +x "$NORMALIZE" 2>/dev/null
    [ -f "$SPEED" ]     && $ESUDO chmod +x "$SPEED"     2>/dev/null
    [ -f "$GCPATCH" ]   && $ESUDO chmod +x "$GCPATCH"   2>/dev/null

    missing=""
    [ -x "$EXTRACTOR" ] || missing="${missing}  tools/rsdkv5u-extract\n"
    [ -f "$FILELIST" ]  || missing="${missing}  tools/RSDKv5UFileList.txt\n"
    [ -x "$VGMSTREAM" ] || missing="${missing}  tools/vgmstream-cli\n"
    [ -x "$OGGENC" ]    || missing="${missing}  tools/oggenc\n"
    [ -x "$NORMALIZE" ] || missing="${missing}  tools/wav-normalize\n"
    [ -x "$SPEED" ]     || missing="${missing}  tools/wav-speed\n"
    [ -x "$GCPATCH" ]   || missing="${missing}  tools/patch-gameconfig\n"
    if [ -n "$missing" ]; then
        echo "ERROR: port is missing required helper tools:"
        printf "$missing"
        echo "Reinstall the port."
        return 1
    fi
    return 0
}

extract_rsdk() {
    [ -f "$ORIGINS" ] || return 0   # pass-through already validated in check_inputs

    echo "Extracting Origins Sonic2u.rsdk..."
    if ! "$EXTRACTOR" "$ORIGINS" "$FILELIST" "$GAMEDIR"; then
        echo "ERROR: Sonic2u.rsdk extraction failed."
        return 1
    fi
    if [ ! -f "$DATADIR/Game/GameConfig.bin" ]; then
        echo "ERROR: extraction produced no GameConfig.bin."
        return 1
    fi
    rm -f "$ORIGINS" "$TARGET"
    patch_gameconfig "$DATADIR/Game/GameConfig.bin"
    echo "Origins data extracted to Data/ and Bytecode/."
}

# Post-extraction GameConfig.bin fixups:
#   1. game.playMode -> 1 (Anniversary mode; enables Drop Dash etc.)
#   2. Players list expanded to the full 7-entry Plus roster so
#      Plus-enabled rebuilds (see BUILDING.md) work without extra RetroED work.
patch_gameconfig() {
    cfg="$1"
    [ -f "$cfg" ] || return 0
    echo "Patching GameConfig.bin:"
    "$GCPATCH" "$cfg" || echo "WARNING: GameConfig patch failed; Drop Dash may not work."
}

