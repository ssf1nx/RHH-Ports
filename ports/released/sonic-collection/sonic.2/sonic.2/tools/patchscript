        *_EmeraldHill2)     echo EmeraldHill2.ogg ;;
        *_ChemicalPlant)    echo ChemicalPlant.ogg ;;
        *_AquaticRuin)      echo AquaticRuin.ogg ;;
        *_CasinoNight)      echo CasinoNight.ogg ;;
        *_CasinoNight2)     echo CasinoNight2.ogg ;;
        *_HillTop)           echo HillTop.ogg ;;
        *_MysticCave)       echo MysticCave.ogg ;;
        *_MysticCave2)      echo MysticCave2.ogg ;;
        *_OilOcean)         echo OilOcean.ogg ;;
        *_Metropolis)       echo Metropolis.ogg ;;
        *_SkyChase)         echo SkyChase.ogg ;;
        *_WingFortress)     echo WingFortress.ogg ;;
        *_DeathEgg)         echo DeathEgg.ogg ;;
        # Menu / system tracks
        *_Options)          echo Options.ogg ;;
        *_SpecialStage)     echo SpecialStage.ogg ;;
        *_Boss)             echo Boss.ogg ;;
        *_FinalBoss)        echo FinalBoss.ogg ;;
        *_Super)            echo Super.ogg ;;
        *_Invincibility)    echo Invincibility.ogg ;;
        *_TitleScreen)      echo Titlescreen.ogg ;;
        *_ActComplete)      echo ActComplete.ogg ;;
        *_GameOver)         echo GameOver.ogg ;;
        *_Results)          echo Results.ogg ;;
        *_Ending)           echo Ending.ogg ;;
        *_Credits)          echo Credits.ogg ;;
        *_Extra)            echo Extra.ogg ;;
        # Continue exists in both music and SFX with the same cue name in
        # STH2_music — the music version goes here; STH2_sfx ships a
        # separate SFX_STH2_3F_Continue that place_sfx routes to
        # Global/Continue.ogg for SfxName[Continue] at end-of-act.
        *_Continue)         echo Continue.ogg ;;
        # *_1up/*_ChaosEmerald/*_Event handled as SFX above.
        # Origins still lacks the _F speed-shoes variants (mobile-only remixes);
        # engine falls back to the un-sped track silently.
        *)                  echo "" ;;
    esac
}

extract_music() {
    [ -f "$MUSIC_AWB" ] || return 0   # already processed or mobile pathway

    echo "$STH2_MUSIC_KEY" > "$GAMEDIR/STH2_music.hcakey"
    mkdir -p "$TMPDIR" "$MUSICDIR"
    rm -f "$TMPDIR"/*.wav 2>/dev/null

    echo "Extracting STH2_music.awb..."
    # -S -1 forces vgmstream to enumerate every subsong. STH2_music.awb has
    # 10 system tracks (ActComplete, GameOver, Titlescreen, etc.) that the
    # ACB's primary cue sheet hides from -S 0 — we lose them without -1.
    # Filenames come out as "<subsong>_<hex>_<name>.wav"; our *_Name globs
    # below still match.
    if ! "$VGMSTREAM" -S -1 -o "$TMPDIR/?s_?n.wav" "$MUSIC_AWB" >/dev/null; then
        echo "ERROR: vgmstream-cli failed on music."
        rm -f "$GAMEDIR/STH2_music.hcakey"
        return 1
    fi
    rm -f "$GAMEDIR/STH2_music.hcakey"

    echo "Encoding to OGG and placing in Music/..."
    count=0
    skipped=0
    mkdir -p "$SFXDIR/Global" "$SFXDIR/Stage"
    for wav in "$TMPDIR"/*.wav; do
        [ -f "$wav" ] || continue
        base=$(basename "$wav" .wav)
        # Several cues in STH2_music.awb are actually SFX in RSDKv4 — the
        # 1up jingle, ChaosEmerald collect, continue-screen drone, and the
        # generic Event sting. Route them to Data/SoundFX/ via place_sfx
        # (which normalizes and emits .ogg for Global, .wav for Stage).
        case "$base" in
            *_1up|*1Up)
                place_sfx "$wav" "Global/1Up.ogg" && count=$((count + 1))
                continue ;;
            *_ChaosEmerald|*ChaosEmerald)
                place_sfx "$wav" "Stage/Emerald.wav" && count=$((count + 1))
                continue ;;
            *_Event|*Event)
                place_sfx "$wav" "Global/Event.ogg" && count=$((count + 1))
                continue ;;
        esac
        target=$(map_music_name "$base")
        if [ -z "$target" ]; then
            skipped=$((skipped + 1))
            continue
        fi
        if "$OGGENC" -Q -q 5 --discard-comments -o "$MUSICDIR/$target" "$wav"; then
            count=$((count + 1))
            # Generate the speed-shoes variant alongside the base for zones
            # that have one in mobile S2. Origins doesn't ship these, so we
            # synthesize by claiming a higher source sample rate (the header
            # trick effectively pitches + tempo-shifts the playback). Mobile's
            # _F tracks are similarly 1.2x the base per the RSDK docs, so
            # this matches the intended effect.
            case "$target" in
                EmeraldHill.ogg|EmeraldHill2.ogg|ChemicalPlant.ogg|\
AquaticRuin.ogg|CasinoNight.ogg|CasinoNight2.ogg|HillTop.ogg|\
MysticCave.ogg|MysticCave2.ogg|OilOcean.ogg|Metropolis.ogg|\
WingFortress.ogg|Invincibility.ogg)
                    f_target="${target%.ogg}_F.ogg"
                    if gen_fast_track "$wav" "$MUSICDIR/$f_target"; then
                        count=$((count + 1))
                    else
                        echo "WARNING: failed to generate $f_target"
                    fi
                    ;;
            esac
        else
            echo "WARNING: failed to encode $base -> $target"
        fi
    done
    echo "Encoded $count tracks ($skipped unmapped)."

    rm -f "$MUSIC_AWB" "$MUSIC_ACB"
    rm -f "$TMPDIR"/*.wav
}

# gen_fast_track <in.wav> <out.ogg>
# Emits a 1.2x-speed OGG variant. wav-speed resamples the PCM data to be
# 1.2x shorter at the original sample rate, so playback preserves pitch but
# moves 1.2x faster — the tempo-only effect mobile's _F tracks have.
gen_fast_track() {
    in="$1"; out="$2"
    [ -f "$in" ] || return 1
    tmp="${in}.fast.wav"
    if ! "$SPEED" 1.2 "$in" "$tmp" 2>/dev/null; then
        rm -f "$tmp"
        return 1
    fi
    "$OGGENC" -Q -q 5 --discard-comments -o "$out" "$tmp" 2>/dev/null
    rv=$?
    rm -f "$tmp"
    return $rv
}

# place_sfx <tmp_wav> <relative_target>
# Moves wav into SFXDIR/$target, normalizing to $SFX_TARGET_DBFS on the way.
# Origins SFX peak anywhere from -2 to -20 dBFS; mobile is consistently loud.
# For .ogg targets (Sonic 2 Global/) we normalize to a temp wav then oggenc.
# Returns 0 on placement, 1 on failure.
place_sfx() {
    src="$1"; rel="$2"
    dst="$SFXDIR/$rel"
    mkdir -p "$(dirname "$dst")"
    case "$rel" in
        *.ogg)
            tmpwav="${src}.norm.wav"
            if "$NORMALIZE" "$SFX_TARGET_DBFS" "$src" "$tmpwav" 2>/dev/null \
               && "$OGGENC" -Q -q 5 --discard-comments -o "$dst" "$tmpwav" 2>/dev/null; then
                rm -f "$src" "$tmpwav"
                return 0
            fi
            rm -f "$tmpwav"
            ;;
        *)
            if "$NORMALIZE" "$SFX_TARGET_DBFS" "$src" "$dst" 2>/dev/null; then
                rm -f "$src"
                return 0
            fi
            ;;
    esac
    # Fall back to plain move if normalize/encode failed (wrong volume / format
    # but at least audible if extension matches).
    mv -f "$src" "$dst" || return 1
    return 0
}

# Pull shared audio from the Sonic 1 Origins packs. S2 references several
# cues that Origins only ships under STH1:
#   STH1_music.awb -> Drowning (music), 1Up (SFX)
#   STH1_sfx.acb   -> ScoreAdd, Event (SFX)
extract_sth1_shared() {
    mkdir -p "$TMPDIR" "$MUSICDIR" "$SFXDIR/Global"

    # --- STH1_music.awb: Drowning + 1Up ---
    if [ -f "$STH1_MUSIC_AWB" ]; then
        echo "$STH1_MUSIC_KEY" > "$GAMEDIR/STH1_music.hcakey"
        rm -f "$TMPDIR"/*.wav 2>/dev/null
        echo "Extracting shared tracks from STH1_music.awb..."
        if "$VGMSTREAM" -S -1 -o "$TMPDIR/?s_?n.wav" "$STH1_MUSIC_AWB" >/dev/null; then
            rm -f "$GAMEDIR/STH1_music.hcakey"

            wav=$(ls "$TMPDIR"/*_Drowning.wav 2>/dev/null | head -n1)
            if [ -z "$wav" ]; then
                echo "WARNING: Drowning cue not found in STH1_music.awb."
            elif "$OGGENC" -Q -q 5 --discard-comments -o "$MUSICDIR/Drowning.ogg" "$wav" 2>/dev/null; then
                echo "Placed Drowning.ogg"
            else
                echo "WARNING: failed to encode Drowning.ogg"
            fi

            wav=$(ls "$TMPDIR"/*_1up.wav 2>/dev/null | head -n1)
            if [ -z "$wav" ]; then
                echo "WARNING: 1up cue not found in STH1_music.awb."
            elif place_sfx "$wav" "Global/1Up.ogg"; then
                echo "Placed Global/1Up.ogg"
            else
                echo "WARNING: failed to place 1Up.ogg"
            fi

            rm -f "$STH1_MUSIC_AWB"
        else
            echo "WARNING: vgmstream-cli failed on STH1_music; Drowning/1Up will be silent."
            rm -f "$GAMEDIR/STH1_music.hcakey"
        fi
        rm -f "$TMPDIR"/*.wav
    fi

    # --- STH1_sfx.acb: ScoreAdd + Event ---
    if [ -f "$STH1_SFX_ACB" ]; then
        echo "$STH1_SFX_KEY" > "$GAMEDIR/STH1_sfx.hcakey"
        rm -f "$TMPDIR"/*.wav 2>/dev/null
        echo "Extracting shared SFX from STH1_sfx.acb..."
        if "$VGMSTREAM" -S 0 -o "$TMPDIR/?n.wav" "$STH1_SFX_ACB" >/dev/null; then
            rm -f "$GAMEDIR/STH1_sfx.hcakey"

            wav="$TMPDIR/SFX_CD_ScoreAdd.wav"
            if [ ! -f "$wav" ]; then
                echo "WARNING: ScoreAdd cue not found in STH1_sfx.acb."
            elif place_sfx "$wav" "Global/ScoreAdd.ogg"; then
                echo "Placed Global/ScoreAdd.ogg"
            else
                echo "WARNING: failed to place ScoreAdd.ogg"
            fi

            wav="$TMPDIR/RSDK-1---Event.wav"
            if [ ! -f "$wav" ]; then
                echo "WARNING: Event cue not found in STH1_sfx.acb."
            elif place_sfx "$wav" "Global/Event.ogg"; then
                echo "Placed Global/Event.ogg"
            else
                echo "WARNING: failed to place Event.ogg"
            fi

            rm -f "$STH1_SFX_ACB"
        else
            echo "WARNING: vgmstream-cli failed on STH1_sfx; ScoreAdd/Event will be silent."
            rm -f "$GAMEDIR/STH1_sfx.hcakey"
        fi
        rm -f "$TMPDIR"/*.wav
    fi
}

extract_sfx() {
    [ -f "$SFX_ACB" ] || return 0

    # STH2_sfx.acb has audio embedded (AFS2 memory) — no sibling AWB.
    echo "$STH2_SFX_KEY" > "$GAMEDIR/STH2_sfx.hcakey"
    mkdir -p "$TMPDIR" "$SFXDIR/Global" "$SFXDIR/Stage"
    rm -f "$TMPDIR"/*.wav 2>/dev/null

    echo "Extracting STH2_sfx.acb..."
    if ! "$VGMSTREAM" -S 0 -o "$TMPDIR/?n.wav" "$SFX_ACB" >/dev/null; then
        echo "ERROR: vgmstream-cli failed on SFX."
        rm -f "$GAMEDIR/STH2_sfx.hcakey"
        return 1
    fi
    rm -f "$GAMEDIR/STH2_sfx.hcakey"

    # RSDKv4 dispatches SFX load by extension (Audio.cpp). Mobile S2 ships
    # Global/ as .ogg and Stage/ as .wav; place_sfx handles the per-target
    # transcode from the normalized WAV.
    echo "Placing SFX in SoundFX/..."
    count=0
    skipped=0
    for wav in "$TMPDIR"/*.wav; do
        [ -f "$wav" ] || continue
        base=$(basename "$wav" .wav)
        target=$(map_sfx_name "$base")
        if [ -z "$target" ]; then
            skipped=$((skipped + 1))
            continue
        fi
        if place_sfx "$wav" "$target"; then
            count=$((count + 1))
        else
            echo "WARNING: failed to place $base -> $target"
        fi
    done
    echo "Placed $count SFX ($skipped unmapped)."

    rm -f "$SFX_ACB"
    rm -f "$TMPDIR"/*.wav
}

# HITE_sfx is the Origins Museum UI soundset. RSDKv4 S2 only needs the
# SEGA chant (Title stage references Stage/Sega.wav) and the "ok" ding
# (used as Global/Select.ogg; RSDK-2---Select is a longer chime).
extract_hite() {
    [ -f "$HITE_ACB" ] || return 0

    echo "$HITE_SFX_KEY" > "$GAMEDIR/HITE_sfx.hcakey"
    mkdir -p "$TMPDIR" "$SFXDIR/Stage"
    rm -f "$TMPDIR"/*.wav 2>/dev/null

    echo "Extracting HITE_sfx.acb..."
    if ! "$VGMSTREAM" -S 0 -o "$TMPDIR/?n.wav" "$HITE_ACB" >/dev/null; then
        echo "ERROR: vgmstream-cli failed on HITE SFX."
        rm -f "$GAMEDIR/HITE_sfx.hcakey"
        return 1
    fi
    rm -f "$GAMEDIR/HITE_sfx.hcakey"

    # HITE cues we use from Origins Museum UI -> RSDKv4 S1 SoundFX paths:
    #   SFX_07_SEGA  -> Stage/Sega.wav    (title chant)
    #   SFX_02_ok    -> Global/Select.ogg (menu accept; RSDK-2---Select is wrong)
    for pair in "SFX_07_SEGA:Stage/Sega.wav" "SFX_02_ok:Global/Select.ogg"; do
        cue="${pair%%:*}"
        dst="${pair#*:}"
        src="$TMPDIR/${cue}.wav"
        if [ ! -f "$src" ]; then
            echo "WARNING: HITE cue $cue missing"
            continue
        fi
        if place_sfx "$src" "$dst"; then
            echo "Placed $cue -> $dst"
        else
            echo "WARNING: failed to place $cue -> $dst"
        fi
    done

    rm -f "$HITE_ACB"
    rm -f "$TMPDIR"/*.wav
}

cleanup() {
    rm -rf "$TMPDIR"
}

process_game() {
    check_tools      || { cleanup; return 1; }
    check_inputs     || { cleanup; return 1; }
    extract_rsdk     || { cleanup; return 1; }
    extract_music    || { cleanup; return 1; }
    extract_sth1_shared || { cleanup; return 1; }
    extract_sfx      || { cleanup; return 1; }
    extract_hite     || { cleanup; return 1; }
    cleanup
}

if ! process_game; then
    echo "Patching process failed!"
    mv "$GAMEDIR/$LOGFILE" "$GAMEDIR/$LOGERR"
else
    echo "Patching process complete!"
fi
