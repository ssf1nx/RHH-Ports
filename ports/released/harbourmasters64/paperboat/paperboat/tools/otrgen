#!/bin/bash

# Set GAMEDIR to the current directory and set logfile
GAMEDIR="$PWD"
LOGFILE="$GAMEDIR/tools/patchlog.txt"
ASSETS_ZIP="$GAMEDIR/tools/assets.zip"
ASSETS_DIR="$GAMEDIR"

rm -rf "$LOGFILE"
exec 3>&1
exec > >(tee -a "$LOGFILE") 2>&1

emit_fail_msg() {
    echo "PATCH_FAIL_MSG:$1" >&3
    echo "$1"
    FAIL_MSG_SET=1
}

echo "GAMEDIR is set to: $GAMEDIR"

# Check if we need to unzip the assets archive
unzip_assets() {
    SEVENZIP="$controlfolder/7zzs.${DEVICE_ARCH}"
    if [ ! -x "$SEVENZIP" ]; then
        emit_fail_msg "7zzs binary not found at $SEVENZIP"
        return 1
    fi

    if [ -f "$ASSETS_ZIP" ]; then
        echo "Extracting assets.zip..."
        if "$SEVENZIP" x -y "$ASSETS_ZIP" -o"$ASSETS_DIR" >/dev/null; then
            rm -f "$ASSETS_ZIP"
        else
            emit_fail_msg "[PATCH] Unable to extract assets.zip."
            return 1
        fi
    fi
}

process_rom() {
    local input_file="$1"
    if [ ! -f "$GAMEDIR/baseroms/$input_file" ]; then
        emit_fail_msg "[PATCH] Error: File $input_file not found!"
        exit 1
    fi

    echo "Extracting data from $input_file..."
    cd "$GAMEDIR"
    if ./tools/torch o2r "$GAMEDIR/baseroms/$input_file" -s "$GAMEDIR" -d "$GAMEDIR"; then
        echo "[PATCH] Extraction complete. pm64.o2r generated."
    else
        emit_fail_msg "[PATCH] Error: Extraction failed for $input_file."
        exit 1
    fi
}

convert_n64() {
    local rom_file="$1"
    local output_file="$GAMEDIR/baseroms/rom.z64"

    if [[ ! -f "$rom_file" ]]; then
        emit_fail_msg "Error: File $rom_file not found!"
        return 1
    fi

    word=$(hexdump -n 4 -e '4/1 "%02x"' "$rom_file")

    case "$word" in
        "37804012")
            echo "[PATCH] Detected Big Endian byte-swap (v64). Converting to z64..."
            dd if="$rom_file" of="$output_file" conv=swab 2>/dev/null || return 1
            ;;
        "40123780")
            echo "[PATCH] Detected Little Endian (n64). Converting to z64..."
            dd if="$rom_file" of="$output_file" conv=swab,notrunc bs=4 2>/dev/null || return 1
            ;;
        "80371240")
            echo "[PATCH] ROM already uses z64 byte ordering. Copying as-is."
            cp "$rom_file" "$output_file" || return 1
            ;;
        *)
            emit_fail_msg "Error: Unknown ROM format for $rom_file."
            return 1
            ;;
    esac

    echo "[PATCH] Conversion complete. Saved as rom.z64."
}

# Main logic
rom_file=$(find "$GAMEDIR/baseroms" -maxdepth 1 \( -name "*.z64" -o -name "*.n64" -o -name "*.v64" \) -print -quit)

if [ -n "$REGEN" ] && [ ! -f "$ASSETS_ZIP" ] && [ ! -d "$GAMEDIR/assets" ]; then
    [ -z "$FAIL_MSG_SET" ] && emit_fail_msg "Regeneration requested but assets/ dir is missing."
    echo "Patching process failed!"
    exit 1
fi

if [ -z "$rom_file" ]; then
    emit_fail_msg "[PATCH] No ROM file found in baseroms/!"
    exit 1
fi

if [ -f "$ASSETS_ZIP" ]; then
    unzip_assets || { echo "Patching process failed!"; exit 1; }
fi

echo "Processing $rom_file..."

case "$rom_file" in
    *.n64|*.v64)
        convert_n64 "$rom_file" || { echo "Patching process failed!"; exit 1; }
        rm -f "$rom_file"
        process_rom "rom.z64" || { echo "Patching process failed!"; exit 1; }
        ;;
    *.z64)
        process_rom "$(basename "$rom_file")" || { echo "Patching process failed!"; exit 1; }
        ;;
esac

echo "Patching process complete!"
