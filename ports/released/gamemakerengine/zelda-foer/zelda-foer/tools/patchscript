#!/bin/bash
# Set GAMEDIR to the current directory and set logfile
GAMEDIR="$PWD"
LOGFILE="patchlog.txt"
LOGERR="patcherr.txt"

# Redirect output and error to the log file
> "$GAMEDIR/$LOGFILE" && exec > >(tee "$GAMEDIR/$LOGFILE") 2>&1
echo "GAMEDIR is set to: $GAMEDIR"

# Exports
export DATADIR="$GAMEDIR/assets"
export DATAFILE="zelda-foer.port"
export TMPDIR="$GAMEDIR/tmp"

prepare_system() {
    # Test for commands: python, zip
    PYTHON=$(which python3)
    if [ -z "$PYTHON" ]; then
        echo "Missing Python!"
        return 1
    fi
    
    # Define 7zzs binary
    SEVENZIP="$controlfolder/7zzs.${DEVICE_ARCH}"
    if [ ! -x "$SEVENZIP" ]; then
        echo "7zzs binary not found at $SEVENZIP"
        return 1
    fi
    
    # Mount the GMToolkit runtime
    TOOLKIT="$HOME/gmtoolkit"
    RUNTIME="$controlfolder/libs/gmtoolkit.squashfs"
    if [ -f "$RUNTIME" ]; then
        $ESUDO mkdir -p "$TOOLKIT"
        $ESUDO umount "$TOOLKIT" 2>/dev/null || true
        $ESUDO mount "$RUNTIME" "$TOOLKIT"
    else
        echo "This port requires the GMToolkit runtime. Please download it."
        return 1
    fi
    
    # Attempt to get SAVEDIR from gmloader.json using jq
    if command -v jq >/dev/null 2>&1; then
        SAVEDIR=$(jq -r '.save_dir // empty' "$GAMEDIR/gmloader.json" 2>/dev/null)
    else
        SAVEDIR="$GAMEDIR/saves"
    fi
    
    # Exports
    export PYTHON
    export SAVEDIR
    export SEVENZIP
    export PATH="$TOOLKIT/gmtools:$TOOLKIT/utmt-cli:$PATH"
    export LD_LIBRARY_PATH="/usr/lib:$TOOLKIT/libs:$LD_LIBRARY_PATH"
}

unzip_archive() {
    # Test for zip file in assets folder and ensure it's the right one
    ZIPFILE="$DATADIR/FOER v1.4.2 (Android).zip"
    APK="$DATADIR/tmp/FOER v1.4.2.apk"
    if [ -f "$ZIPFILE" ]; then
        if "$SEVENZIP" x -y "$ZIPFILE" -o"$DATADIR/tmp" >/dev/null; then
            rm -rf "$ZIPFILE"
            # Now unzip the apk
            if [ -f "$APK" ]; then
                # Unzip the apk and remove the cruft
                if "$SEVENZIP" x -y "$APK" -o"$DATADIR/tmp" >/dev/null; then
                    rm -rf "$APK"
                    prepare_files
                else
                    echo "Failed to unzip apk."
                    return 1
                fi
            else
                echo "The archive did not have $APK inside!"
                return 1
            fi
        else
            echo "Failed to unzip archive."
            return 1
        fi
    else
        echo "Did not find archive $ZIPFILE!"
        return 1
    fi
}

prepare_files() {
    mkdir -p "$SAVEDIR"
    
    # Delete excess files
    find "$DATADIR/tmp" -type f \( \
        -name "*.2" -o -name "*.arsc" -o -name "*.dex" -o -name "*.txt" -o -name "*.xml" -o \
    \) -exec rm -f {} \;
    
    # Delete excess folders
    rm -rf "$DATADIR/.gitkeep"
    rm -rf "$DATADIR/tmp/res"
    rm -rf "$DATADIR/tmp/META-INF"

    # Move splash file if it exists
    if [ -f "$DATADIR/tmp/assets/splash.png" ]; then
        mv "$DATADIR/tmp/assets/splash.png" "$GAMEDIR/splash.png"
    fi
    
    # Compress audio
    compress_audio
    
    # Move extracted content up
    mv "$DATADIR/tmp/assets" "$DATADIR/" 2>/dev/null
    mv "$DATADIR/tmp/lib" "$DATADIR/" 2>/dev/null
    rm -rf "$DATADIR/tmp"
}

# Compress audio files inside datafile and audiogroups
compress_audio() {
    # Purge cache before operations
    rm -rf "$TMPDIR/"*

    # Run the compression tool
    PYTHON=$(which python3)
    echo "Running GMTools on data and audiogroups."
    $PYTHON "$TOOLKIT/gmtools/gmKtool.py" -vv -m 1000 -r -b 64 -d "$TMPDIR" "$DATADIR/tmp/assets/game.droid"

    if [ $? -eq 0 ]; then
        echo "Compression completed successfully."
        mv "$TMPDIR/"* "$DATADIR/tmp/assets"
        echo "Moved compressed files to $DATADIR."
        rm -rf "$TMPDIR"
        echo "Temporary directory $TMPDIR removed."
        echo "Audio compression applied successfully."
    else
        # Failure
        echo "Audio compression failed."
        [ -d "$TMPDIR" ] && rm -rf "$TMPDIR"/*
        return 1
    fi
}

zip_archive() {
    echo "Building $DATAFILE..."
    if "$SEVENZIP" a -tzip -aoa -mx=0 "$GAMEDIR/$DATAFILE" "$DATADIR"/* >/dev/null; then
        echo "$DATAFILE created successfully."
        rm -rf "$DATADIR"/*
    else
        echo "Failed to create $DATAFILE."
        return 1
    fi
}

# Cleanup
cleanup() {
    rm -rf "$TMPDIR"
    $ESUDO umount "$TOOLKIT" 2>/dev/null || true
}

process_game() {
    echo "Preparing system..."
    prepare_system || { cleanup; return 1; }
    echo "Unzipping archive..."
    unzip_archive || { cleanup; return 1; }
    echo "Creating .port archive..."
    zip_archive || { cleanup; return 1; }
}

# Call the function
if ! process_game; then
    echo "Patching process failed!"
    mv "$LOGFILE" "$LOGERR"
else
    echo "Patching process complete!"
fi

# Always run cleanup at the end
cleanup
