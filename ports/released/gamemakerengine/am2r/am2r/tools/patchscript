#!/bin/bash
# Set GAMEDIR to the current directory and set logfile
GAMEDIR="$PWD"
LOGFILE="patchlog.txt"
LOGERR="patcherr.txt"

# Redirect output and error to the log file
rm -f "$GAMEDIR/$LOGERR"
# Save the patcher's pipe (original stdout) on fd 3 before redirecting stdout
# through tee. This lets emit_fail_msg send dialog overrides straight to the
# patcher GUI without them appearing in patchlog.txt.
exec 3>&1
> "$GAMEDIR/$LOGFILE" && exec > >(tee "$GAMEDIR/$LOGFILE") 2>&1

emit_fail_msg() {
    echo "PATCH_FAIL_MSG:$1" >&3
    echo "$1"
    FAIL_MSG_SET=1
}


# Exports
export DATADIR="$GAMEDIR/assets"
export DATAFILE="am2r.port"
export TMPDIR="$GAMEDIR/tmp"

prepare_system() {
    # Test for python
    PYTHON=$(command -v python3)
    if [ -z "$PYTHON" ]; then
        emit_fail_msg "Missing Python!"
        return 1
    fi
    
    # Define 7zzs binary
    SEVENZIP="$controlfolder/7zzs.${DEVICE_ARCH}"
    if [ ! -x "$SEVENZIP" ]; then
        emit_fail_msg "7zzs binary not found at $SEVENZIP"
        return 1
    fi
    
    # Attempt to get SAVEDIR from gmloader.json using jq
    if command -v jq >/dev/null 2>&1; then
        SAVEDIR=$(jq -r '.save_dir // empty' "$GAMEDIR/gmloader.json" 2>/dev/null)
    else
        SAVEDIR="$GAMEDIR/saves"
    fi

    export PYTHON
    export SAVEDIR
    export SEVENZIP
}

unzip_archives() {
    # Create folders
    mkdir -p "$DATADIR/am2r" "$DATADIR/am2rpatch"
    AM2R_ZIP=""
    AUTOPATCHER_ZIP=""
    AM2R16B_ZIP="AM2R_1.6b2_windows.zip"

    # Bail early if we don't have 1.6b
    if [ ! -f "$DATADIR/$AM2R16B_ZIP" ]; then
        emit_fail_msg "AM2R 1.6b patch not found."
        return 1
    fi

    # Determine authenticity of other zips
    for zip in "$DATADIR"/*.zip; do

        # Identify AM2R zip (data.win in root)
        if "$SEVENZIP" l "$zip" | grep -q 'data.win'; then
            AM2R_ZIP="$zip"
        # Identify autopatcher zip (has AM2R-Autopatcher-Windows-master/data/)
        elif "$SEVENZIP" l "$zip" | grep -q 'AM2R-Autopatcher-Windows-master/data'; then
            AUTOPATCHER_ZIP="$zip"
        fi
    done

    # Report results
    [ -n "$AM2R_ZIP" ] || { echo "Missing AM2R base zip"; return 1; }

    # HQ audio is optional
    if [ -n "$AUTOPATCHER_ZIP" ]; then
        echo "Autopatcher zip detected: $AUTOPATCHER_ZIP"
    else
        echo "No Autopatcher zip found. Will proceed without HQ audio."
    fi

    # Unzip AM2R and autopatcher
    "$SEVENZIP" x -y "$AM2R_ZIP" -o"$DATADIR/am2r" >/dev/null
    [ -n "$AUTOPATCHER_ZIP" ] && "$SEVENZIP" x -y "$AUTOPATCHER_ZIP" -o"$DATADIR/am2rpatch" >/dev/null 2>&1
}

prepare_files() {
    # Remove unnecessary files
    rm -rf "$DATADIR/am2r/"*.exe "$DATADIR/am2r/"*.dll "$DATADIR/.gitkeep" "$DATADIR/am2r/"*.txt

    # Apply autopatcher files if present
    if [ -n "$AUTOPATCHER_ZIP" ]; then
        cp -rf "$DATADIR/am2rpatch/AM2R-Autopatcher-Windows-master/data/files_to_copy/"* "$DATADIR/am2r/"
    fi

    # Unzip 1.6b patch
    "$SEVENZIP" x -y "$DATADIR/$AM2R16B_ZIP" -o"$DATADIR/am2r16b" >/dev/null
    cp -rf "$DATADIR/am2r16b/files_to_copy/"* "$DATADIR/am2r/"
    [ -n "$AUTOPATCHER_ZIP" ] && cp -rf "$DATADIR/am2rpatch/AM2R-Autopatcher-Windows-master/data/HDR_HQ_in-game_music/"* "$DATADIR/am2r/"
}

apply_xdelta() {
    local data="$1"
    local patch_file="$2"
    local tmp_out="${data}.patched"
    local output

    if [ ! -f "$data" ]; then
        emit_fail_msg "Source file not found: $data"
        return 1
    fi

    output=$("$controlfolder/xdelta3" -d -s "$data" "$patch_file" "$tmp_out" 2>&1)
    if [ $? -ne 0 ]; then
        emit_fail_msg "Failed to apply patch: $patch_file"
        echo "$output"
        rm -f "$tmp_out"
        return 1
    fi

    mv "$tmp_out" "$data"
    echo "Patch applied successfully."
}

clean_files() {  
    mkdir -p "$TMPDIR"

    # Move everything from am2r into TMPDIR
    if [ -d "$DATADIR/am2r" ]; then
        mv "$DATADIR/am2r/"* "$TMPDIR/" 2>/dev/null
        mv "$DATADIR/am2r/".* "$TMPDIR/" 2>/dev/null || true  # Hidden files (except . and ..)
        rmdir "$DATADIR/am2r" 2>/dev/null || true
    fi

    # Clean all contents of assets directory (DATADIR)
    rm -rf "$DATADIR/"*

    # Move everything back from TMPDIR to DATADIR
    mv "$TMPDIR/"* "$DATADIR/" 2>/dev/null
    mv "$TMPDIR/".* "$DATADIR/" 2>/dev/null || true

    # Clean TMPDIR
    rm -rf "$TMPDIR/"*
    
}

# Zip it all into the .port file
zip_archive() {
    [ -f "$DATADIR/data.win" ] && mv "$DATADIR/data.win" "$DATADIR/game.droid"
    if "$SEVENZIP" a -tzip -aoa -mx=0 "$GAMEDIR/$DATAFILE" "$DATADIR" >/dev/null; then
        rm -rf "$DATADIR"/*
    else
        emit_fail_msg "Failed to create $DATAFILE."
        return 1
    fi
}

# Cleanup function
cleanup() {
    rm -rf "$TMPDIR"
}

process_game() {
    echo "Checking for dependencies..."
    prepare_system || { cleanup; return 1; }
    echo "Unzipping archives..."
    unzip_archives || { cleanup; return 1; }
    echo "Preparing game..."
    prepare_files || { cleanup; return 1; }
    echo "Applying 1.6b2 patch..."
    apply_xdelta "$DATADIR/am2r/data.win" "$DATADIR/am2r16b/data.xdelta" || { cleanup; return 1; }
    if [ "$ASPECTPATCH" ]; then
        echo "Applying 3:2 patch..."
        apply_xdelta "$DATADIR/am2r/data.win" "$GAMEDIR/tools/am2r16b2_3-2.xdelta" || { cleanup; return 1; }
    fi
    echo "Cleaning excess files..."
    clean_files || { cleanup; return 1; }
    echo "Finishing up..."
    zip_archive || { cleanup; return 1; }
}

# Call the function
if ! process_game; then
    [ -z "$FAIL_MSG_SET" ] && emit_fail_msg "Patching failed. Report on the RHH-Ports GitHub with patcherr.txt."
    echo "Patching process failed!"
    mv "$LOGFILE" "$LOGERR"
else
    echo "Patching process complete!"
fi

# Always run cleanup at the end
cleanup
