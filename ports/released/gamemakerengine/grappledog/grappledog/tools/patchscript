#!/bin/bash
# Set GAMEDIR to the current directory and set logfile
GAMEDIR="$PWD"
LOGFILE="patchlog.txt"
LOGERR="patcherr.txt"

# Redirect output and error to the log file
rm -f "$GAMEDIR/$LOGERR"
exec 3>&1
> "$GAMEDIR/$LOGFILE" && exec > >(tee "$GAMEDIR/$LOGFILE") 2>&1

emit_fail_msg() {
    echo "PATCH_FAIL_MSG:$1" >&3
    echo "$1"
    FAIL_MSG_SET=1
}

echo "GAMEDIR is set to: $GAMEDIR"

# Exports
export DATADIR="$GAMEDIR/assets"
export LICENSEDIR="$GAMEDIR/licenses/grappledog"
export DATAFILE="grappledog.port"

prepare_system() {
    ZIP=$(command -v zip)
    if [ -z "$ZIP" ]; then
        emit_fail_msg "Missing zip!"
        return 1
    fi

    DECODER="$GAMEDIR/tools/yyg_qoi_decode"
    if [ ! -x "$DECODER" ]; then
        emit_fail_msg "yyg_qoi_decode binary not found at $DECODER"
        return 1
    fi

    # Resolve SAVEDIR from gmloader.json; ensure it's absolute under GAMEDIR.
    if command -v jq >/dev/null 2>&1; then
        SAVEDIR_REL=$(jq -r '.save_dir // empty' "$GAMEDIR/gmloader.json" 2>/dev/null)
        SAVEDIR="$GAMEDIR/${SAVEDIR_REL:-saves}"
    else
        SAVEDIR="$GAMEDIR/saves"
    fi
    export DECODER SAVEDIR
}

prepare_assets() {
    # Delete files we don't need
    rm -rf "$DATADIR"/*.exe "$DATADIR"/*.dll "$DATADIR"/.gitkeep "$DATADIR"/grappledog_data

    mkdir -p "$SAVEDIR" "$LICENSEDIR"
    [ -d "$DATADIR/fmodBanks" ] && mv "$DATADIR/fmodBanks" "$SAVEDIR/fmodBanks"
    [ -d "$DATADIR/licenses" ] && mv "$DATADIR/licenses/"* "$LICENSEDIR"
    rmdir "$DATADIR/licenses" 2>/dev/null || true
    # If user pre-patched on a PC, they'll have a textures/ folder bundled in
    # with assets/ -- move it where the texhack expects to find it.
    if [ -d "$DATADIR/textures" ]; then
        mv "$DATADIR/textures" "$SAVEDIR/textures"
    fi
}

externalize_textures() {
    mkdir -p "$SAVEDIR/textures"
    echo "Repacking texture pages and compressing at ASTC $PATCH_BLOCK $PATCH_QUALITY..."
    # One yyg_qoi_decode pass does texture externalization + InfoFlags toggle
    # + GMS2RandomUID recompute. (Previously a Python tools/toggleflags.py ran
    # the InfoFlags step separately, which is why we used to require python3.)
    if ! "$DECODER" "$DATADIR/data.win" "$SAVEDIR/textures" \
            --repack --page-size 1024 \
            --block "$PATCH_BLOCK" --quality "$PATCH_QUALITY" $PATCH_THREADS \
            --set-flags Fullscreen --clear-flags Scale; then
        emit_fail_msg "Texture compression failed."
        return 1
    fi
}

# Tighter devices need fewer threads during patching
PATCH_THREADS=""
ORIG_MAX_FREQS=""
if [ "${DEVICE_RAM:-0}" -le 2 ]; then
    PATCH_THREADS="--threads 1"
fi

# Scale ASTC block size + quality to screen pixel count.
SCREEN_PIXELS=$(( ${DISPLAY_WIDTH:-640} * ${DISPLAY_HEIGHT:-480} ))
if [ "$SCREEN_PIXELS" -le 480000 ]; then
    PATCH_BLOCK="6x6"
    PATCH_QUALITY="-fastest"
elif [ "$SCREEN_PIXELS" -le 1000000 ]; then
    PATCH_BLOCK="5x5"
    PATCH_QUALITY="-fast"
else
    PATCH_BLOCK="4x4"
    PATCH_QUALITY="-medium"
fi

thermal_setup() {
    for policy in /sys/devices/system/cpu/cpufreq/policy*; do
        [ -d "$policy" ] && [ -f "$policy/scaling_max_freq" ] || continue
        orig=$(cat "$policy/scaling_max_freq") || continue
        target=$((orig * 8 / 10))
        $ESUDO sh -c "echo $target > '$policy/scaling_max_freq'" 2>/dev/null || true
        ORIG_MAX_FREQS="$ORIG_MAX_FREQS|$policy=$orig"
    done
}

thermal_restore() {
    OLDIFS=$IFS
    IFS='|'
    for entry in $ORIG_MAX_FREQS; do
        [ -z "$entry" ] && continue
        policy="${entry%=*}"
        orig="${entry#*=}"
        $ESUDO sh -c "echo $orig > '$policy/scaling_max_freq'" 2>/dev/null || true
    done
    IFS=$OLDIFS
}

# Add assets to $DATAFILE
zip_archive() {
        echo "Finishing up..."
        [ -f "$DATADIR/data.win" ] && mv "$DATADIR/data.win" "$DATADIR/game.droid"
        zip -r -0 "$DATAFILE" ./assets/
        rm -rf "$DATADIR"/*
        sleep 1
}

process_game() {
    prepare_system || return 1
    # Detect PC-pre-patched assets BEFORE prepare_assets moves them away.
    PRE_PATCHED=0
    [ -d "$DATADIR/textures" ] && PRE_PATCHED=1
    prepare_assets || return 1
    if [ "$PRE_PATCHED" = 1 ]; then
        echo "Pre-patched assets detected; skipping on-device texture compression."
    else
        if [ "${DEVICE_RAM:-0}" -le 2 ]; then thermal_setup; fi
        if ! externalize_textures; then
            if [ -n "$ORIG_MAX_FREQS" ]; then thermal_restore; fi
            return 1
        fi
        if [ -n "$ORIG_MAX_FREQS" ]; then thermal_restore; fi
    fi
    zip_archive || return 1
}

# Call the function
if ! process_game; then
    [ -z "$FAIL_MSG_SET" ] && emit_fail_msg "Patching failed. Report on the RHH-Ports GitHub with patcherr.txt."
    echo "Patching process failed!"
    mv "$LOGFILE" "$LOGERR"
else
    echo "Patching process complete!"
fi
