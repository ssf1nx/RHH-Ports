#!/bin/bash
# Set GAMEDIR to the current directory and set logfile
GAMEDIR="$PWD"
LOGFILE="patchlog.txt"
LOGERR="patcherr.txt"

# Redirect output and error to the log file
rm -f "$GAMEDIR/$LOGERR"
# Save the patcher pipe (original stdout) on fd 3 before redirecting stdout
# through tee. This lets emit_fail_msg send dialog overrides straight to the
# patcher GUI without them appearing in patchlog.txt.
exec 3>&1
> "$GAMEDIR/$LOGFILE" && exec > >(tee "$GAMEDIR/$LOGFILE") 2>&1

emit_fail_msg() {
    echo "PATCH_FAIL_MSG:$1" >&3
    echo "$1"
    FAIL_MSG_SET=1
}

echo "GAMEDIR is set to: $GAMEDIR"

# Exports
export DATADIR="$GAMEDIR/assets"
export SAVEDIR="$GAMEDIR/saves"
export DATAFILE="undertaleredyellow.port"

# Tight-RAM devices can't sustain a parallel astcenc / vorbis workload.
THREADS_FLAG=""
if [ "${DEVICE_RAM:-0}" -le 2 ]; then
    THREADS_FLAG="--threads 1"
fi

# Pick ASTC block/quality based on display size. Smaller screens don't need 4x4 medium.
SCREEN_PIXELS=$(( ${DISPLAY_WIDTH:-640} * ${DISPLAY_HEIGHT:-480} ))
if [ "$SCREEN_PIXELS" -le 480000 ]; then
    BLOCK_FLAGS="--block 6x6 --quality fastest"
elif [ "$SCREEN_PIXELS" -le 1000000 ]; then
    BLOCK_FLAGS="--block 5x5 --quality fast"
else
    BLOCK_FLAGS=""
fi

ORIG_MAX_FREQS=""
thermal_setup() {
    for policy in /sys/devices/system/cpu/cpufreq/policy*; do
        [ -d "$policy" ] && [ -f "$policy/scaling_max_freq" ] || continue
        orig=$(cat "$policy/scaling_max_freq") || continue
        target=$((orig * 8 / 10))
        $ESUDO sh -c "echo $target > '$policy/scaling_max_freq'" 2>/dev/null || true
        ORIG_MAX_FREQS="$ORIG_MAX_FREQS|$policy=$orig"
    done
}

thermal_restore() {
    OLDIFS=$IFS
    IFS='|'
    for entry in $ORIG_MAX_FREQS; do
        [ -z "$entry" ] && continue
        policy="${entry%=*}"
        orig="${entry#*=}"
        $ESUDO sh -c "echo $orig > '$policy/scaling_max_freq'" 2>/dev/null || true
    done
    IFS=$OLDIFS
}

prepare_files() {
    mkdir -p "$SAVEDIR"

    # Pick up the user-supplied UTRY zip if present, extract the base xdelta.
    MOD_ZIP=""
    for f in "$DATADIR"/*.zip; do
        [ -f "$f" ] || continue
        case "$(basename "$f")" in *UTRY*|*utry*) MOD_ZIP="$f"; break;; esac
    done
    if [ -n "$MOD_ZIP" ]; then
        mkdir -p "$DATADIR/utry"
        if ! unzip -o "$MOD_ZIP" -d "$DATADIR/utry"; then
            emit_fail_msg "Failed to extract $(basename "$MOD_ZIP")."
            return 1
        fi
        rm -f "$MOD_ZIP"
        for f in "$DATADIR/utry/"*.ogg; do [ -f "$f" ] && mv "$f" "$DATADIR/"; done
        [ -f "$DATADIR/utry/splash.png" ] && mv "$DATADIR/utry/splash.png" "$GAMEDIR/"
        BASEPATCH=$(find "$DATADIR/utry" -maxdepth 1 -type f -name "Undertale*1.08*to*UTRY*.xdelta" | head -n 1)
        if [ -z "$BASEPATCH" ]; then
            emit_fail_msg "Did not find base UTRY xdelta in the supplied zip."
            return 1
        fi
        mkdir -p "$GAMEDIR/tools/patches"
        mv "$BASEPATCH" "$GAMEDIR/tools/patches/utry_steam.xdelta"
        rm -rf "$DATADIR/utry"
    elif [ ! -f "$GAMEDIR/tools/patches/utry_steam.xdelta" ]; then
        emit_fail_msg "Missing UTRY zip and no cached xdelta. Drop the UTRY mod zip into assets/."
        return 1
    fi

    find "$DATADIR" -type f \( \
        -name "*.gitkeep" -o -name "*.exe" -o -name "*.dll" -o -name "*.hashdb" -o \
        -name "*.ico" -o -name "*.lnk" -o -name "*.msg" -o -name "*.zip" \
    \) -exec rm -f {} \;

    if [ -d "$SAVEDIR/textures" ]; then
        rm -rf "$SAVEDIR/textures"
    fi
}

apply_xdelta() {
    if [ ! -f "$DATADIR/data.win" ]; then
        emit_fail_msg "No data.win. Copy Undertale Steam or GOG 1.08 data.win into assets/."
        return 1
    fi
    local sum=$(md5sum "$DATADIR/data.win" | awk '{print $1}')
    local STEAMSUM="5903fc5cb042a728d4ad8ee9e949c6eb"
    local GOGSUM="ff4f10d0434b332f46e1f35a900ec862"
    if [ "$sum" != "$STEAMSUM" ] && [ "$sum" != "$GOGSUM" ]; then
        emit_fail_msg "data.win md5 doesn't match Undertale Steam or GOG 1.08."
        return 1
    fi
    if [ "$sum" = "$GOGSUM" ]; then
        echo "GOG data detected; converting to Steam first..."
        if ! "$controlfolder/xdelta3" -d -s "$DATADIR/data.win" -f "$GAMEDIR/tools/patches/rhh-gog-to-steam.xdelta" "$DATADIR/data2.win"; then
            emit_fail_msg "GOG-to-Steam xdelta failed."
            return 1
        fi
        mv -f "$DATADIR/data2.win" "$DATADIR/data.win"
    fi
    echo "Applying UTRY xdelta..."
    if ! "$controlfolder/xdelta3" -d -s "$DATADIR/data.win" -f "$GAMEDIR/tools/patches/utry_steam.xdelta" "$DATADIR/data2.win"; then
        emit_fail_msg "UTRY xdelta failed."
        return 1
    fi
    rm -f "$DATADIR/data.win"
    mv "$DATADIR/data2.win" "$DATADIR/data.win"
}

patch_datafile() {
    if ! "$controlfolder/gmtoolkit.${DEVICE_ARCH}" --config "$GAMEDIR/tools/undertaleredyellow.json" $THREADS_FLAG $BLOCK_FLAGS "$DATADIR/data.win"; then
        emit_fail_msg "gmtoolkit patch failed."
        return 1
    fi
}

# Zip it all into the .port file
zip_archive() {
    [ -f "$DATADIR/data.win" ] && mv "$DATADIR/data.win" "$DATADIR/game.droid"
    local zip_out
    if zip_out=$("$controlfolder/7zzs.${DEVICE_ARCH}" a -tzip -aoa -mx=0 "$GAMEDIR/$DATAFILE" "$DATADIR" 2>&1); then
        rm -rf "$DATADIR"/*
    else
        echo "$zip_out"
        emit_fail_msg "Failed to create $DATAFILE."
        return 1
    fi
}

process_game() {
    echo "Preparing game..."
    prepare_files || return 1
    echo "Applying xdelta patches..."
    apply_xdelta || return 1
    thermal_setup
    echo "Applying patches..."
    patch_datafile
    rc=$?
    thermal_restore
    [ "$rc" -ne 0 ] && return 1
    echo "Finishing up..."
    zip_archive || return 1
}

if ! process_game; then
    [ -z "$FAIL_MSG_SET" ] && emit_fail_msg "Patching failed. Report on the RHH-Ports GitHub with patcherr.txt."
    echo "Patching process failed!"
    mv "$LOGFILE" "$LOGERR"
    exit 1
fi
echo "Patching process complete!"
